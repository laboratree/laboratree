# ------------------------------------------------------------------
# Laboratree environment. Copy to .env and fill in secrets.
# In docker-compose, host values are overridden to service names.
# All infra vars have safe dev defaults in settings, so they are optional locally.
# ------------------------------------------------------------------

# --- LLM provider selection: "azure" | "openai" ---
LLM_PROVIDER=azure

# --- Azure OpenAI (used when LLM_PROVIDER=azure) ---
# The OpenAI-compatible v1 route works for gpt-5.x AND serverless models (DeepSeek).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_V1_ENDPOINT=https://<resource>.openai.azure.com/openai/v1
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_TEMPERATURE=0
# Optional role-specific model overrides (fall back to the deployment above):
GENERATION_MODEL=gpt-5.4-mini
REASONING_MODEL=gpt-5.4-mini

# --- Plain OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- App ---
APP_ENV=development
API_PORT=8000
WEB_PORT=3000
SECRET_KEY=change-me-in-prod-please-use-a-long-random-string
LOG_LEVEL=INFO

# --- Postgres (+ pgvector) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=laboratree
POSTGRES_PASSWORD=laboratree
POSTGRES_DB=laboratree

# --- Redis (Celery broker/result, cache, pub/sub) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Neo4j (graph: walkthrough, provenance/lineage, knowledge graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=laboratree
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# --- MongoDB (documents: parsed papers, extraction blocks, agent traces) ---
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=laboratree
MONGO_PASSWORD=laboratree
MONGO_DB=laboratree

# --- Blob storage (local for now; empty BLOB_LOCAL_ROOT -> auto <repo>/data/blobs) ---
BLOB_BACKEND=local
BLOB_LOCAL_ROOT=

# --- Web search (dataset discovery + evidence) ---
# Provider order: brave first, serpapi fallback. Keys are secret — never commit real values.
WEB_SEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=
SERPAPI_KEY=

# --- Scholarly evidence (Ideation deep agent) — free academic databases, no key required ---
# OpenAlex: keyless; set a contact email for the faster "polite pool" (optional).
OPENALEX_ENABLED=true
OPENALEX_MAILTO=
# Semantic Scholar: keyless works but is rate-limited; a free key raises the limit (optional).
SEMANTIC_SCHOLAR_ENABLED=true
SEMANTIC_SCHOLAR_API_KEY=

# --- Rate limiting + caching (Redis-backed; both fail open if Redis is down) ---
RATE_LIMIT_ENABLED=true
IDEATION_CACHE_ENABLED=true
IDEATION_CACHE_TTL_S=86400
