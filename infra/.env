# Published container ports ONLY — no secrets. Compose reads THIS file for ${VAR:-default}
# interpolation (env_file: ../.env only reaches the containers, not the port mappings).
# Values mirror the root .env (standard ports are taken by other projects on this machine).
POSTGRES_PORT=5433
MONGO_PORT=27018
NEO4J_BOLT_PORT=7689
REDIS_PORT=6379
